# ==============================================================================
# RenderReply Backend Configuration - Environment Secrets Example
# ==============================================================================
# Copy this file to '.env' and populate with actual credentials.
# Do NOT check your live '.env' into git version control.

# Server Execution Port
PORT=3000
NODE_ENV=development

# Firebase Admin Service Account Configuration
# Paste the ENTIRE firebase-service-account.json stringified single-line JSON here.
# Example: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"renderrelys",...}
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json_string

# Meta OAuth App Setup (Instagram Graph API integration)
# Generate/read these at: https://developers.facebook.com -> Your App Settings -> Basic
META_APP_ID=992956679850018
META_APP_SECRET=your_meta_app_secret_here

# Meta OAuth Callback Redirect URI
# MUST match exactly with the redirect URIs in the Facebook developer console settings.
# Development: http://localhost:3000/auth/instagram/callback
# Production:  https://api.renderreply.com/auth/instagram/callback
META_REDIRECT_URI=https://api.renderreply.com/auth/instagram/callback

# Mobile App Deep Linking URI Schema
# Development (Expo Go): exp://192.168.1.10:8081 (Or your Expo LAN IP)
# Production:             renderreply://oauth/callback
DEEP_LINK_URI=renderreply://oauth/callback

# Upstash Redis Connection Endpoint (Caching & Poll Rate Limiting)
# Create a free database at: https://upstash.com -> copy the raw Redis URL (starting with rediss://)
REDIS_URL=rediss://default:your_redis_password@your_upstash_host.upstash.io:6379

# Cryptographic AES-256-GCM Token Encryption Key
# MUST be a robust secret key. To generate a 32-byte (256-bit) cryptographically secure hex key:
# Run in terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# CORS Whitelist Origins
# Comma-separated list of allowed origins. Left empty to allow all local requests.
# Production: ALLOWED_ORIGINS=https://yourapp.com,http://localhost:8081,http://localhost:8082
ALLOWED_ORIGINS=https://api.renderreply.com,http://localhost:8081,http://localhost:8082

# Instagram Access Token (Dev / Mock connections auto seeding)
# Skip if doing standard Meta OAuth login. Paste a valid long-lived user token to auto-connect mock developer user.
INSTAGRAM_ACCESS_TOKEN=IGAAVXmO5L6...
